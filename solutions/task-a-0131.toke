M=checkStrictlyIncreasing;I=j:std.json;I=s:std.str;F=main():void{let input=s.argv(1);let parsed=j.parse(input);let result=checkStrictlyIncreasing(parsed);j.print(result);};F=checkStrictlyIncreasing(arr:[i64]):bool{if(arr.len=0 as u64){<true};if(arr.len=1 as u64){<true};let n=arr.len;let m=mut.0;lp(let i=0;i<n-1 as u64;i=i+1){let current=arr[i];let next=arr[i+1 as u64];if(!(current<next)){<false};};<true};