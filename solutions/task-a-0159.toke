M=rle;I=j:std.json;I=s:std.str;F=main():void{let input=j.parse(s.argv(1));let result=encode(input);j.print(result);};F=encode(arr:[i64]):Str{let n=arr.len;if(n=0 as u64){<""};let result=mut."";let i=mut.0 as u64;lp(let i=0 as u64;i<n;i=i+1){let current=arr[i];let count=mut.1;let j=mut.i+1;lp(let k=i+1;k<n;k=k+1){if(arr[k]=current){count=count+1;j=k+1}el{br}};result=result+current as Str;if(count>1){result=result+":count"};i=j-1};<result};