M=bsearch;I=j:std.json;I=s:std.str;F=main():void{let input=j.parse(s.argv(1));let arr=input[0];let target=input[1];let result=bsearch(arr;target);j.print(result);};F=bsearch(arr:[i64];target:i64):i64{let left=mut.0;let right=mut.arr.len;right=right-1;lp(let i=0;i<100;i=i+1){if(!(left<right)){br};let mid=mut.(left+right)/2;let midVal=arr[mid];if(midVal=target){<mid};if(midVal<target){left=mid+1}el{right=mid-1};};<0-1};