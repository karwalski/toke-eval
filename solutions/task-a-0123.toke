M=primes;I=j:std.json;I=s:std.str;F=main():void{let n=j.parse(s.argv(1));let result=primes(n);j.print(result);};F=primes(n:i64):[i64]{if(n<2){<[]};let sieve=mut.[true;true;true;true;true;true;true;true;true;true];let i=mut.0;lp(let i=0;i<n+1;i=i+1){if(i<sieve.len){sieve[i]=true}};sieve[0]=false;sieve[1]=false;lp(let p=2;p*p<n+1;p=p+1){if(sieve[p]){lp(let m=p*p;m<n+1;m=m+p){if(m<sieve.len){sieve[m]=false}}}};let result=mut.[];lp(let i=2;i<n+1;i=i+1){if(sieve[i]){result=result+[i]}};<result};