M=checkStrictlyDecreasing;I=j:std.json;I=s:std.str;F=main():void{let input=s.argv(1);let parsed=j.parse(input);let result=checkStrictlyDecreasing(parsed);j.print(result);};F=checkStrictlyDecreasing(arr:[i64]):bool{if(arr.len=0 as u64){<true};if(arr.len=1 as u64){<true};let n=arr.len;lp(let i=0 as u64;i<n-1 as u64;i=i+1){let val=arr[i];let other=arr[i+1 as u64];if(val=other){<false};if(val<other){<false};};<true};