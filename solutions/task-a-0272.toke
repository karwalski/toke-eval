M=main;I=j:std.json;I=s:std.str;F=main():void{let input=j.parse(s.argv(1));let result=sortCount(input);j.print(result);};F=sortCount(arr:[i64]):[[i64]]{let n=arr.len;let unique=mut.[];let counts=mut.[];lp(let i=0;i<n;i=i+1){let val=arr[i];let found=mut.false;let idx=mut.0;lp(let j=0;j<unique.len;j=j+1){if(unique[j]=val){found=true;idx=j;};};if(found){counts[idx]=counts[idx]+1;}el{unique=unique+[val];counts=counts+[1];};};let m=unique.len;lp(let i=0;i<m;i=i+1){lp(let j=0;j+1<m-i;j=j+1){if(unique[j]>unique[j+1]){let tmp=unique[j];unique[j]=unique[j+1];unique[j+1]=tmp;let tmpc=counts[j];counts[j]=counts[j+1];counts[j+1]=tmpc;};};};let result=mut.[];lp(let i=0;i<m;i=i+1){result=result+[[unique[i];counts[i]]];};<result};