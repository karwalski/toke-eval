M=longestIncRun;I=j:std.json;I=s:std.str;F=main():void{let input=j.parse(s.argv(1));let arr=input as [i64];let result=longestIncRun(arr);j.print(result);};F=longestIncRun(arr:[i64]):i64{let n=arr.len;if(n=0 as u64){<0};let longest=mut.1;let current=mut.1;lp(let i=1;i<n;i=i+1){let val=arr[i-1];let other=arr[i];if(val=other){<longest};if(val<other){current=current+1}el{if(current>longest){longest=current};current=1};};if(current>longest){longest=current};<longest};