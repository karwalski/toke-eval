M=reverseint;I=j:std.json;I=s:std.str;F=main():void{let input=j.parse(s.argv(1));let n=input as i64;let result=reverseInt(n);j.print(result);};F=reverseInt(n:i64):i64{let isNeg=false;let absN=n;if(n<0){let isNeg=true;let absN=0-n};let result=mut.0;let temp=absN;lp(let i=0;temp>0;i=i+1){let digit=temp-temp/10*10;let result=result*10+digit;let temp=temp/10};if(isNeg){<0-result}el{<result}};