M=wordcount;I=j:std.json;I=s:std.str;F=main():void{let input=j.parse(s.argv(1));let result=wordCount(input);j.print(result);};F=wordCount(s:Str):i64{let n=s.len;let count=mut.0;let inWord=mut.false;lp(let i=0;i<n;i=i+1){let c=s[i];if(c=32){if(inWord){count=count+1;inWord=false}}el{inWord=true}};if(inWord){count=count+1};<count};