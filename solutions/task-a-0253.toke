M=mode;I=j:std.json;I=s:std.str;F=main():void{let input=j.parse(s.argv(1));let arr=input as [i64];let result=mode(arr);j.print(result);};F=mode(arr:[i64]):i64{let n=arr.len;if(n=0){<-1};let maxCount=mut.0;let modeVal=mut.arr[0];lp(let i=0;i<n;i=i+1){let current=arr[i];let count=mut.0;lp(let j=0;j<n;j=j+1){if(arr[j]=current){count=count+1;};};if(count>maxCount){maxCount=count;modeVal=current;}el{if(count=maxCount){if(current<modeVal){modeVal=current;};};};};<modeVal};