M=main;I=j:std.json;I=s:std.str;F=main():void{let input=j.parse(s.argv(1));let arr=input as [i64];let n=arr.len;let minIdx=mut.0;let minVal=mut.arr[0];lp(let i=1;i<n;i=i+1){if(arr[i]<minVal){minVal=arr[i];minIdx=i;};};let sum=mut.0;lp(let i=0;i<n;i=i+1){if(!(i=minIdx)){sum=sum+arr[i];};};j.print(sum);};