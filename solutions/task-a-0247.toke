M=primefactors;I=j:std.json;I=s:std.str;F=main():void{let n=j.parse(s.argv(1));let result=primeFactors(n);j.print(result);};F=primeFactors(n:i64):[i64]{let result=mut.[];let remaining=mut.n;lp(let i=2;!(i>remaining);i=i+1){let isDivisible=mut.false;let temp=mut.remaining;lp(let j=0;!(j=0);j=j+1){if(temp-i<0){isDivisible=true;br;};temp=temp-i;};if(isDivisible){result=result+[i];remaining=temp;};};<result};