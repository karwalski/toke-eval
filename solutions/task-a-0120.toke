M=main;I=j:std.json;I=s:std.str;F=main():void{let n=j.parse(s.argv(1));let result=mut.[];if(n=0){<j.print(result)};result=result+[0];if(n=1){<j.print(result)};result=result+[1];if(n=2){<j.print(result)};let a=mut.0;let b=mut.1;lp(let i=2;i<n;i=i+1){let next=a+b;a=b;b=next;result=result+[b]};<j.print(result)};