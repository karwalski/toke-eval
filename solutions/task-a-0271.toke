M=flatten;I=j:std.json;I=s:std.str;F=main():void{let input=j.parse(s.argv(1));let result=flatten(input);j.print(result);};F=flatten(arr:[[[i64]]]):[i64]{let result=mut.[];let outer=arr.len;lp(let i=0;i<outer;i=i+1){let inner=arr[i];let innerLen=inner.len;lp(let j=0;j<innerLen;j=j+1){let sub=inner[j];let subLen=sub.len;lp(let k=0;k<subLen;k=k+1){result=result+[sub[k]];};};};<result};