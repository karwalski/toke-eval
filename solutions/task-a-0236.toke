M=countOccurrences;I=j:std.json;I=s:std.str;F=main():void{let input=j.parse(s.argv(1));let s=input[0];let sub=input[1];let count=countOccurrences(s;sub);j.print(count);};F=countOccurrences(s:Str;sub:Str):i64{let n=s.len;let m=sub.len;if(m>n){<0};if(m=0){<0};let count=mut.0;let i=mut.0;lp(let i=0;i<n-m+1;i=i+1){let match=mut.true;let j=mut.0;lp(let j=0;j<m;j=j+1){if(s[i+j]=sub[j]){}el{match=false;br;};};if(match){count=count+1;i=i+m-1;};};<count};