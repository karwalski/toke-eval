M=merge;I=j:std.json;I=s:std.str;F=main():void{let input=j.parse(s.argv(1));let a=input[0];let b=input[1];let result=mergeSorted(a;b);j.print(result);};F=mergeSorted(x:[i64];y:[i64]):[i64]{let i=mut.0;let j=mut.0;let result=mut.[];lp(let k=0;k<x.len+y.len;k=k+1){if(i<x.len){if(j<y.len){if(x[i]<y[j]){result=result+[x[i]];i=i+1;}el{result=result+[y[j]];j=j+1;};}el{result=result+[x[i]];i=i+1;};}el{if(j<y.len){result=result+[y[j]];j=j+1;};};};<result};