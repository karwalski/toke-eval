M=mostFreq;I=j:std.json;I=s:std.str;F=main():void{let input=j.parse(s.argv(1));let arr=input as [i64];let result=mostFreq(arr);j.print(result);};F=mostFreq(arr:[i64]):i64{let n=arr.len;let maxFreq=mut.0;let maxVal=mut.0;lp(let i=0;i<n;i=i+1){let val=arr[i];let freq=mut.0;lp(let j=0;j<n;j=j+1){if(arr[j]=val){freq=freq+1;};};if(freq>maxFreq){maxFreq=freq;maxVal=val;}el{if(freq=maxFreq){if(val<maxVal){maxVal=val;};};};};<maxVal};