M=upperbound;I=j:std.json;I=s:std.str;F=main():void{let input=j.parse(s.argv(1));let arr=input[0];let target=input[1];let result=upperBound(arr;target);j.print(result);};F=upperBound(arr:[i64];target:i64):i64{let left=mut.0;let right=mut.arr.len;lp(let i=0;i<100;i=i+1){if(!(left<right)){br};let mid=left+(right-left)/2;let midVal=arr[mid];if(midVal>target){right=mid;}el{left=mid+1;};};<left};