M=prefixmax;I=j:std.json;I=s:std.str;F=main():void{let input=s.argv(1);let parsed=j.parse(input);let result=prefixMax(parsed);j.print(result);};F=prefixMax(arr:[i64]):[i64]{let n=arr.len;let result=mut.[];let currentMax=mut.0;lp(let i=0;i<n;i=i+1){let elem=arr[i];if(i=0){currentMax=elem}el{if(elem>currentMax){currentMax=elem}};result=result+[currentMax];};<result};