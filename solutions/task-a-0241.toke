M=main;I=j:std.json;I=s:std.str;F=main():void{let input=j.parse(s.argv(1));let arr=input[0];let targets=input[1];let result=smallestSubarray(arr;targets);j.print(result);};F=smallestSubarray(arr:[i64];targets:[i64]):i64{if(targets.len=0 as u64){<0};let targetSet=mut.[];lp(let i=0 as u64;i<targets.len;i=i+1){let val=targets[i];let found=mut.false;lp(let j=0 as u64;j<targetSet.len;j=j+1){if(targetSet[j]=val){found=true;br;};};if(!(found)){targetSet=targetSet+[val];};};let n=arr.len;let m=targetSet.len;let minLen=mut.n+1;let left=mut.0;let right=mut.0;let found=mut.false;lp(let i=0 as u64;i<n;i=i+1){let current=arr[i];let inTargets=mut.false;lp(let j=0 as u64;j<m;j=j+1){if(targetSet[j]=current){inTargets=true;br;};};if(inTargets){if(!(found)){left=i as i64;found=true;};right=i as i64;};};if(!(found)){<-1};let currentLen=right-left+1;if(currentLen<minLen){minLen=currentLen;};<minLen};