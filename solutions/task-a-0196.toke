M=parseint;I=j:std.json;I=s:std.str;F=main():void{let input=j.parse(s.argv(1));let result=parseInt(input);j.print(result);};F=parseInt(s:Str):i64{let n=s.len;let result=mut.0;let idx=mut.0;let isNeg=mut.false;if(idx<n){let ch=s[idx];if(ch=45){isNeg=true;idx=idx+1;}};if(idx=n){<0};let num=mut.0;lp(let i=idx;i<n;i=i+1){let ch=s[i];let digit=ch-48;if(digit<0){<0};if(digit>9){<0};num=num*10+digit;};if(isNeg){num=0-num};<num};