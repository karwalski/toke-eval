M=main;I=j:std.json;I=s:std.str;F=main():void{let input=j.parse(s.argv(1));let arr=input as [i64];let n=arr.len;let maxSum=mut.0;let currentSum=mut.0;lp(let i=0;i<n;i=i+1){let num1=arr[i];let num2=currentSum+num1;if(num2>num1){currentSum=num2}el{currentSum=num1};if(currentSum>maxSum){maxSum=currentSum}};j.print(maxSum)};