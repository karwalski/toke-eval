M=rotation;I=j:std.json;I=s:std.str;F=main():void{let input=j.parse(s.argv(1));let a=input[0];let b=input[1];let result=rotateCheck(a;b);j.print(result);};F=rotateCheck(a:Str;b:Str):bool{if(a.len=b.len){let doubled=a+a;let found=mut.false;lp(let i=0;i<doubled.len-b.len+1;i=i+1){let match=mut.true;lp(let j=0;j<b.len;j=j+1){if(!(doubled[i+j]=b[j])){match=false;};};if(match){found=true;};};<found}el{<false}};