M=secondsmallest;I=j:std.json;I=s:std.str;F=main():void{let input=s.argv(1);let parsed=j.parse(input);let arr=parsed as [i64];let n=arr.len;let smallest=mut.arr[0];let second=mut.arr[0];let i=mut.0;lp(let j=0;j<n;j=j+1){let curr=arr[j];if(curr<smallest){second=smallest;smallest=curr;}el{if(!(curr=smallest)){if(curr<second){second=curr;}}}};j.print(second);};