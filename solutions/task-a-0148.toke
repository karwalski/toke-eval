M=runlen;I=j:std.json;I=s:std.str;F=main():void{let input=j.parse(s.argv(1));let result=runLengthDecode(input);j.print(result);};F=runLengthDecode(arr:[[i64]]):[i64]{let n=arr.len;let result=mut.[];lp(let i=0;i<n;i=i+1){let val=arr[i][0];let count=arr[i][1];let m=mut.0;lp(let j=0;j<count;j=j+1){result=result+[val];};};<result};