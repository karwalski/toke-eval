M=peak;I=j:std.json;I=s:std.str;F=main():void{let input=j.parse(s.argv(1));let arr=input as [i64];let result=mut.-1;let n=arr.len;if(n=0 as u64){<j.print(result)};if(n=1 as u64){<j.print(0)};lp(let i=0;i<n;i=i+1){let isPeak=mut.false;if(i=0 as u64){if(arr[i]>arr[i+1 as u64]){isPeak=true}};if(i=n-1 as u64){if(arr[i]>arr[i-1 as u64]){isPeak=true}};if(!(i=0 as u64)){if(!(i=n-1 as u64)){if(arr[i]>arr[i-1 as u64]){if(arr[i]>arr[i+1 as u64]){isPeak=true}}}};if(isPeak){result=i as i64;br}};j.print(result)};