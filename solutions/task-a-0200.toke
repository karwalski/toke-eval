M=longestIncSubseq;I=j:std.json;I=s:std.str;F=main():void{let input=s.argv(1);let arr=j.parse(input);let result=longestIncSubseq(arr);j.print(result);};F=longestIncSubseq(arr:[i64]):i64{let n=arr.len;if(n=0){<0};let dp=mut.[];lp(let i=0;i<n;i=i+1){dp=dp+[1];};lp(let i=1;i<n;i=i+1){lp(let j=0;j<i;j=j+1){if(arr[j]<arr[i]){let dpj=dp[j];let dpi=dp[i];if(dpj+1>dpi){dp[i]=dpj+1;};};};};let maxLen=mut.0;lp(let i=0;i<n;i=i+1){let curr=dp[i];if(curr>maxLen){maxLen=curr;};};<maxLen};