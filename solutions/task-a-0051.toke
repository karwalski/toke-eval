M=arrnegate;I=j:std.json;I=s:std.str;F=main():void{let input=j.parse(s.argv(1));let result=arrNegate(input);j.print(result);};F=arrNegate(arr:[i64]):[i64]{let n=arr.len;let result=mut.[];lp(let i=0;i<n;i=i+1){let elem=arr[i];let negated=mut.0;if(elem>0){negated=0-elem}el{if(elem<0){negated=0-elem}el{negated=0}};result=result+[negated];};<result};