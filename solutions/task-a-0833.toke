M=evenfilter;I=j:std.json;I=s:std.str;F=main():void{let input=s.argv(1);let parsed=j.parse(input);let result=evenFilter(parsed);j.print(result);};F=evenFilter(arr:[i64]):[i64]{let result=mut.[];lp(let i=0;i<arr.len;i=i+1){let elem=arr[i];let mod=elem-elem/2*2;if(mod=0){result=result+[elem];};};<result};