M=slidingmax;I=j:std.json;I=s:std.str;F=main():void{let input=s.argv(1);let parsed=j.parse(input);let arr=parsed[0];let k=parsed[1];let result=slidingMax(arr;k);j.print(result);};F=slidingMax(arr:[i64];k:i64):[i64]{let n=arr.len;let result=mut.[];let i=mut.0;lp(let i=0;i<n-k+1;i=i+1){let max=mut.arr[i];let j=mut.i+1;lp(let j=i+1;j<i+k;j=j+1){if(arr[j]>max){max=arr[j];};};result=result+[max];};<result};