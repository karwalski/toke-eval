M=replace;I=j:std.json;I=s:std.str;F=main():void{let input=j.parse(s.argv(1));let arr=input as [Str];let old=arr[1];let new=arr[2];let s=arr[0];let n=s.len;let oldlen=old.len;let result=mut."";let i=mut.0;lp(let i=0;i<n;i=i+1){if(!(i+oldlen>n)){let match=mut.true;lp(let j=0;j<oldlen;j=j+1){if(!(s[i+j]=old[j])){match=false;};};if(match){result=result+new;i=i+oldlen-1;}el{result=result+s[i];};}el{result=result+s[i];};};j.print(result);};