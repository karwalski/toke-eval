M=runlen;I=j:std.json;I=s:std.str;F=main():void{let input=j.parse(s.argv(1));let result=runLength(input);j.print(result);};F=runLength(arr:[i64]):[[i64]]{let n=arr.len;if(n=0 as u64){<[]};let result=mut.[];let current=mut.arr[0];let count=mut.1;lp(let i=1;i<n;i=i+1){let x=arr[i];let y=current;if(x=y){count=count+1}el{result=result+[[current;count]];current=x;count=1}};result=result+[[current;count]];<result};