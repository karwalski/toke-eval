M=partition;I=j:std.json;I=s:std.str;F=main():void{let input=s.argv(1);let parsed=j.parse(input);let arr=parsed[0];let pivot=parsed[1];let result=partition(arr;pivot);j.print(result);};F=partition(arr:[i64];pivot:i64):[[i64]]{let less=mut.[];let equal=mut.[];let greater=mut.[];lp(let i=0;i<arr.len;i=i+1){let elem=arr[i];if(elem<pivot){less=less+[elem];}el{if(elem=pivot){equal=equal+[elem];}el{greater=greater+[elem];};};};<[less;equal;greater]};