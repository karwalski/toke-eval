M=titleCase;I=j:std.json;I=s:std.str;F=main():void{let input=j.parse(s.argv(1));let result=toTitleCase(input);j.print(result);};F=toTitleCase(s:Str):Str{let n=s.len;let result=mut."";let capitalizeNext=mut.true;lp(let i=0;i<n;i=i+1){let c=s[i];if(c=32){result=result+" ";capitalizeNext=true;}el{if(capitalizeNext){if(c>96){if(c<123){c=c-32;};};result=result+(c as Str);capitalizeNext=false;}el{result=result+(c as Str);};};};<result};