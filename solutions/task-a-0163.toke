M=interleave;I=j:std.json;I=s:std.str;F=main():void{let input=j.parse(s.argv(1));let arr1=input[0];let arr2=input[1];let result=interleave(arr1;arr2);j.print(result);};F=interleave(a:[i64];b:[i64]):[i64]{let n=a.len;let result=mut.[];lp(let i=0;i<n;i=i+1){result=result+[a[i]];result=result+[b[i]];};<result};