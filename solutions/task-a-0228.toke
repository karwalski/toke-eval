M=removeZeros;I=j:std.json;I=s:std.str;F=main():void{let input=j.parse(s.argv(1));let result=removeZeros(input);j.print(result);};F=removeZeros(arr:[i64]):[i64]{let n=arr.len;let result=mut.[];let inZeroRun=mut.false;lp(let i=0;i<n;i=i+1){let elem=arr[i];if(elem=0){if(inZeroRun){}el{result=result+[0];inZeroRun=true;};}el{result=result+[elem];inZeroRun=false;};};<result};