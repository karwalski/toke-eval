M=runlen;I=j:std.json;I=s:std.str;F=main():void{let input=j.parse(s.argv(1));let result=runLength(input);j.print(result);};F=runLength(s:Str):Str{let n=s.len;if(n=0){<""};let result=mut."";let current=mut.s[0];let count=mut.1;lp(let i=1;i<n;i=i+1){if(s[i]=current){count=count+1}el{result=result+current;if(count>1){result=result+count as Str};current=s[i];count=1}};result=result+current;if(count>1){result=result+count as Str};<result};