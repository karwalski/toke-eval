M=uniquecount;I=j:std.json;I=s:std.str;F=main():void{let input=j.parse(s.argv(1));let arr=input as [i64];let result=uniqueCount(arr);j.print(result);};F=uniqueCount(arr:[i64]):i64{let n=arr.len;let count=mut.0;lp(let i=0;i<n;i=i+1){let found=mut.false;lp(let j=0;j<i;j=j+1){if(arr[j]=arr[i]){found=true;};};if(!(found)){count=count+1;};};<count};