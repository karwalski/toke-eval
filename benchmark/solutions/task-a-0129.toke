M=checkNonDecreasing;I=j:std.json;I=s:std.str;F=main():void{let input=s.argv(1);let parsed=j.parse(input);let result=checkNonDecreasing(parsed);j.print(result);};F=checkNonDecreasing(arr:[i64]):bool{let n=arr.len;let m=mut.0;lp(let i=0;i+1<n;i=i+1){let curr=arr[i];let next=arr[i+1];if(curr>next){<false};};<true};