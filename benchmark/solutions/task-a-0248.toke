M=largestPrimeFactor;F=main():void{let n=12;let result=largestPrimeFactor(n);<result};F=largestPrimeFactor(n:i64):i64{let x=n;let y=mut.2;let result=mut.1;lp(let i=0;i<1;i=i+1){if(x=2){result=2};if(!(x=2)){let isPrime=mut.true;let divisor=mut.2;lp(let j=0;j<1;j=j+1){if(divisor*divisor>x){isPrime=false};if(isPrime){let remainder=x-x/divisor*divisor;if(remainder=0){isPrime=false}};divisor=divisor+1};if(isPrime){result=x}}};<result};