M=sorteddiff;I=j:std.json;I=s:std.str;F=main():void{let input=j.parse(s.argv(1));let first=input[0];let second=input[1];let result=sortedDiff(first;second);j.print(result);};F=sortedDiff(first:[i64];second:[i64]):[i64]{let result=mut.[];let i=mut.0;let j=mut.0;lp(let i=0;i<first.len;i=i+1){let elem=first[i];if(elem<0){result=result+[elem];}el{let found=mut.false;lp(let j=0;j<second.len;j=j+1){if(second[j]=elem){found=true;};};if(!(found)){result=result+[elem];};};};<result};