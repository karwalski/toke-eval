M=substring;I=j:std.json;I=s:std.str;F=main():void{let input=j.parse(s.argv(1));let s=input[0];let sub=input[1];let result=mut.false;let n=s.len;let m=sub.len;if(!(m>n)){let found=mut.false;lp(let i=0;i<n-m+1;i=i+1){let match=mut.true;lp(let j=0;j<m;j=j+1){if(!(s[i+j]=sub[j])){match=false}};if(match){found=true}};result=found};j.print(result)};