M=median;I=j:std.json;I=s:std.str;F=main():void{let input=j.parse(s.argv(1));let arr=mut.[];lp(let i=0;i<input.len;i=i+1){arr=arr+[input[i]];};let sorted=mut.[];lp(let i=0;i<arr.len;i=i+1){sorted=sorted+[arr[i]];};lp(let i=0;i<sorted.len;i=i+1){lp(let j=0;j+1<sorted.len;j=j+1){if(sorted[j]>sorted[j+1]){let tmp=sorted[j];sorted[j]=sorted[j+1];sorted[j+1]=tmp;};};};let len=sorted.len;let isEven=mut.false;if(len-len/2*2=0){isEven=true;};let result=mut.0;if(isEven){let mid1=sorted[len/2-1];let mid2=sorted[len/2];if(mid1>mid2){result=mid1;}el{result=mid2;};}el{result=sorted[len/2];};j.print(result);};