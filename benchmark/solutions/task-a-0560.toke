M=removeDups;I=j:std.json;I=s:std.str;F=main():void{let input=j.parse(s.argv(1));let result=removeDups(input);j.print(result);};F=removeDups(arr:[i64]):[i64]{let n=arr.len;let result=mut.[];lp(let i=0;i<n;i=i+1){let val=arr[i];let found=mut.false;lp(let j=0;j<result.len;j=j+1){let other=result[j];if(val=other){found=true;br;};};if(!(found)){result=result+[val];};};<result};