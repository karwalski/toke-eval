M=longestCommonPrefix;F=commonPrefix(val:Str;other:Str):Str{if(val=other){<val};let vlen=val.len;let olen=other.len;let minlen=mut.vlen;if(olen<vlen){minlen=olen};let i=mut.0 as u64;lp(let j=0 as u64;j<minlen;j=j+1){if(!(val[j]=other[j])){i=j;br};i=j+1};let result=mut."";lp(let k=0 as u64;k<i;k=k+1){result=result+val[k]as Str};<result};F=longestCommonPrefix(val:Str;other:Str):Str{if(val=other){<val};let vlen=val.len;let olen=other.len;let minlen=mut.vlen;if(olen<vlen){minlen=olen};let i=mut.0 as u64;lp(let j=0 as u64;j<minlen;j=j+1){if(!(val[j]=other[j])){i=j;br};i=j+1};let result=mut."";lp(let k=0 as u64;k<i;k=k+1){result=result+val[k]as Str};<result};F=longestCommonPrefixCommonprefix(val:Str;other:Str):Str{<longestCommonPrefix(commonPrefix(val;other))};F=main():void{let input=std.json.parse(std.io.read());let val=input[0];let other=input[1];let result=longestCommonPrefix(val;other);std.io.write(result);};