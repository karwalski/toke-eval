M=prefixMin;I=j:std.json;I=s:std.str;F=main():void{let input=s.argv(1);let parsed=j.parse(input);let result=prefixMin(parsed);j.print(result);};F=prefixMin(arr:[i64]):[i64]{let n=arr.len;let result=mut.[];let currentMin=mut.0;if(n>0){currentMin=arr[0];result=result+[currentMin];lp(let i=1;i<n;i=i+1){let current=arr[i];if(current<currentMin){currentMin=current;};result=result+[currentMin];};};<result};