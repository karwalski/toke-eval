M=containsAtPos;I=j:std.json;I=s:std.str;F=main():void{let input=j.parse(s.argv(1));let s=input[0];let sub=input[1];let pos=input[2];let result=containsAtPos(s;sub;pos);j.print(result);};F=containsAtPos(s:Str;sub:Str;pos:i64):bool{let slen=s.len;let sublen=sub.len;let pos64=pos as u64;if(!(pos64<slen)){<false};if(!(sublen>0 as u64)){<true};let canMatch=mut.true;lp(let i=0 as u64;i<sublen;i=i+1){let sidx=pos64+i;if(!(sidx<slen)){canMatch=false};if(canMatch){let schar=s[sidx];let subchar=sub[i];if(!(schar=subchar)){canMatch=false}}};<canMatch};