M=prime;I=j:std.json;I=s:std.str;F=main():void{let n=j.parse(s.argv(1));let r=mut.0;let count=mut.0;let candidate=mut.2;lp(let i=0;i<n;i=i+1){let isPrime=mut.true;let divisor=mut.2;lp(let j=0;j<candidate;j=j+1){if(divisor*divisor>candidate){br};let rem=candidate-candidate/divisor*divisor;if(rem=0){isPrime=false;br};divisor=divisor+1};if(isPrime){count=count+1};if(count=n){r=candidate;br};candidate=candidate+1};j.print(r)};