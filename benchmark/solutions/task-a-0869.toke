M=intersect;I=j:std.json;I=s:std.str;F=main():void{let input=j.parse(s.argv(1));let a=input[0];let b=input[1];let result=intersect(a;b);j.print(result);};F=intersect(a:[i64];b:[i64]):[i64]{let result=mut.[];lp(let i=0;i<a.len;i=i+1){let elem=a[i];let found=mut.false;lp(let j=0;j<b.len;j=j+1){if(b[j]=elem){found=true;};};if(found){let alreadyIn=mut.false;lp(let k=0;k<result.len;k=k+1){if(result[k]=elem){alreadyIn=true;};};if(!(alreadyIn)){result=result+[elem];};};};<result};