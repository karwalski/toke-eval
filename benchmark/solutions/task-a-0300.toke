M=main;I=j:std.json;I=s:std.str;F=main():void{let input=j.parse(s.argv(1));let arr=input as [i64];let result=helper(arr);j.print(result);};F=helper(arr:[i64]):[i64]{let n=arr.len;if(n=0 as u64){<[]};let maxStart=mut.0;let maxEnd=mut.0;let maxSum=mut.0;let currentStart=mut.0;let currentSum=mut.0;lp(let i=0 as u64;i<n;i=i+1){let current=arr[i];if(currentSum>0){currentSum=currentSum+current}el{currentSum=current;currentStart=i};if(currentSum>maxSum){maxSum=currentSum;maxStart=currentStart;maxEnd=i}};<[maxStart as i64;maxEnd as i64;maxSum]};