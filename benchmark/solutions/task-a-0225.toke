M=merge;I=j:std.json;I=s:std.str;F=main():void{let input=j.parse(s.argv(1));let result=mergeSort(input);j.print(result);};F=mergeSort(arrs:[[i64]]):[i64]{let merged=mut.[];lp(let i=0;i<arrs.len;i=i+1){let current=arrs[i];let j=mut.0;let k=mut.0;let temp=mut.[];lp(let k=0;k<merged.len;k=k+1){temp=temp+[merged[k]];};let merged=mut.temp;let j=mut.0;let k=mut.0;lp(let k=0;k<current.len;k=k+1){let currentVal=current[k];let mergedVal=merged[j];if(currentVal<mergedVal){merged=merged+[currentVal];j=j+1;}el{merged=merged+[mergedVal];j=j+1;};};};<merged};