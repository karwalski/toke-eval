M=zigzag;I=j:std.json;I=s:std.str;F=main():void{let input=j.parse(s.argv(1));let val=input as i64;let other=mut.val;if(val=other){<val};let isNeg=mut.false;if(val<0){isNeg=true;val=0-val};let result=mut.0;let power=mut.1;lp(let i=0;i<64;i=i+1){let bit=val-val/2*2;if(bit=1){result=result+power};power=power+power;val=val/2};if(isNeg){result=0-result};j.print(result)};