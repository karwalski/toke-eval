M=secondlargest;I=j:std.json;I=s:std.str;F=main():void{let input=j.parse(s.argv(1));let arr=input as [i64];let n=arr.len;let m=mut.0;let largest=mut.arr[0];let second=mut.arr[0];lp(let i=0;i<n;i=i+1){let curr=arr[i];if(curr>largest){second=largest;largest=curr;}el{if(!(curr=largest)){if(curr>second){second=curr;}}}};j.print(second);};