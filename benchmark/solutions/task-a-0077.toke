M=tolower;I=j:std.json;I=s:std.str;F=main():void{let input=j.parse(s.argv(1));let result=toLower(input);j.print(result);};F=toLower(val:Str):Str{let n=val.len;let result=mut."";lp(let i=0;i<n;i=i+1){let c=val[i];if(c>64){if(c<91){result=result+(c+32 as Str);}el{result=result+(c as Str);};}el{result=result+(c as Str);};};<result};