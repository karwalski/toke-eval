M=rot13;I=j:std.json;I=s:std.str;F=main():void{let input=j.parse(s.argv(1));let result=rot13(input);j.print(result);};F=rot13(s:Str):Str{let n=s.len;let result=mut."";lp(let i=0;i<n;i=i+1){let c=s[i];let shifted=mut.c;if(c>64){if(c<91){shifted=c-65;shifted=shifted+13;shifted=shifted-shifted/26*26;shifted=shifted+65;}el{if(c>96){if(c<123){shifted=c-97;shifted=shifted+13;shifted=shifted-shifted/26*26;shifted=shifted+97;};};};};result=result+shifted as Str;};<result};