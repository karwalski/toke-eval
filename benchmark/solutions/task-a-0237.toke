M=interleave;I=j:std.json;I=s:std.str;F=main():void{let input=j.parse(s.argv(1));let arr=input as [Str];let x=arr[0];let y=arr[1];let result=interleave(x;y);j.print(result);};F=interleave(x:Str;y:Str):Str{let lenX=x.len;let lenY=y.len;let minLen=mut.0;if(lenX<lenY){minLen=lenX;}el{minLen=lenY;};let result=mut."";lp(let i=0;i<minLen;i=i+1){result=result+(x[i]as Str);result=result+(y[i]as Str);};if(lenX>minLen){lp(let i=minLen;i<lenX;i=i+1){result=result+(x[i]as Str);};};if(lenY>minLen){lp(let i=minLen;i<lenY;i=i+1){result=result+(y[i]as Str);};};<result;};