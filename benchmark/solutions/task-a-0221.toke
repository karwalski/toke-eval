M=sort;I=j:std.json;I=s:std.str;F=main():void{let input=j.parse(s.argv(1));let arr=input as [i64];let result=sort(arr);j.print(result);};F=sort(arr:[i64]):[i64]{let evens=mut.[];let odds=mut.[];lp(let i=0;i<arr.len;i=i+1){let elem=arr[i];let mod=elem-elem/2*2;if(mod=0){evens=evens+[elem];}el{odds=odds+[elem];};};let sortedEvens=sortHelper(evens);let sortedOdds=sortHelper(odds);let result=sortedEvens+sortedOdds;<result};F=sortHelper(arr:[i64]):[i64]{let n=arr.len;let result=mut.arr;lp(let i=0;i<n;i=i+1){lp(let j=0;j<n-1;j=j+1){let lhs=result[j];let rhs=result[j+1];if(lhs>rhs){let tmp=result[j];result[j]=result[j+1];result[j+1]=tmp;};};};<result};